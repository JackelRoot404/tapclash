# Template for android/keystore.properties (which is gitignored).
# Copy this file to android/keystore.properties and fill in the real values to
# build a signed release. app/build.gradle reads these and refuses to build a
# release AAB/APK if they are absent (it will not silently fall back to the
# debug key).
TAPCLASH_STORE_FILE=tapclash-release.keystore
TAPCLASH_KEY_ALIAS=tapclash
TAPCLASH_STORE_PASSWORD=
TAPCLASH_KEY_PASSWORD=
